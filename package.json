{
  "name": "promptpad",
  "version": "2.2.0",
  "description": "A compact, always-on-top notepad widget for writing AI prompts",
  "main": "main.js",
  "author": "PromptPad",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.raminturne.promptpad",
    "productName": "PromptPad",
    "copyright": "Copyright © 2026 PromptPad",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icon.ico"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "PromptPad",
      "requestedExecutionLevel": "asInvoker",
      "signDlls": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PromptPad",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "maintainer": "PromptPad"
    }
  }
}
